# Python virtual env (huge: torch, etc.)
.venv/
__pycache__/
*.pyc

# Photo database — NOT tracked
photos.db
photos.db-wal
photos.db-shm

# Generated / cached artifacts
.thumbs/
busy/

# Server logs (rotating)
web_demo/server.log
web_demo/server.log.*

# Default sample image folder — keep the dir + marker, not the photos
default-image/*
!default-image/PUT_YOUR_IMAGES_HERE.txt

# Model weights (large, downloadable)
*.pt
models/

# OS
Thumbs.db
.DS_Store
